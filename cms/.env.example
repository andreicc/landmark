# Landmark CMS — env vars
# Copy to .env.local for local dev, or paste into Vercel project settings.
# Generate PAYLOAD_SECRET with: openssl rand -base64 32

PAYLOAD_SECRET=

# Supabase Postgres
# Use the POOLER URL (transaction mode, port 6543) on Vercel serverless,
# NOT the direct connection (port 5432). Direct connections will exhaust
# under cold-start spikes.
#
# Find it in: Supabase Dashboard → Project Settings → Database →
#   Connection string → "Transaction" pooler. Copy the URI value.
# Replace [YOUR-PASSWORD] with the DB password you set when creating the project.
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# Vercel Blob — Vercel Dashboard → Storage → connect Blob → Read/Write token
BLOB_READ_WRITE_TOKEN=

# Public URLs of the static site (used for live-preview + CORS allowlist)
SITE_URL=https://landmark.example
SITE_URL_RO=https://landmark.example/ro

# Optional: read-only API token for build-time fetch from the static site (Phase 4)
# Generate inside Payload admin → API Keys after first deploy.
# BUILD_FETCH_TOKEN=
